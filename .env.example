# Anthropic Claude API Configuration
VITE_ANTHROPIC_API_KEY=sk_ant_your_api_key_here
VITE_CLAUDE_MODEL=claude-sonnet-4-20250514

# Application Environment
VITE_APP_ENV=development
VITE_LOG_LEVEL=info
VITE_DEBUG_MODE=false

# Analytics Configuration
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_ENDPOINT=https://api.analytics.example.com

# Email Service Configuration (Optional)
VITE_SMTP_HOST=smtp.gmail.com
VITE_SMTP_PORT=587
VITE_SMTP_SECURE=true
VITE_SMTP_USER=your-email@gmail.com
VITE_SMTP_PASSWORD=your-app-password
VITE_SMTP_FROM=noreply@mailflow.dev

# Campaign Configuration
VITE_MAX_RECIPIENTS_PER_CAMPAIGN=50000
VITE_MAX_RETRIES=3
VITE_RETRY_DELAY_MS=1000

# Compliance Settings
VITE_REQUIRE_COMPLIANCE_CHECK=true
VITE_AUTO_COMPLIANCE_REPORT=true
VITE_STORE_COMPLIANCE_LOGS=true

# Feature Flags
VITE_FEATURE_MULTI_AGENT=true
VITE_FEATURE_HUMAN_APPROVAL=true
VITE_FEATURE_REAL_TIME_LOGS=true
VITE_FEATURE_A_B_TESTING=false

# API Configuration
VITE_API_TIMEOUT_MS=30000
VITE_API_RETRY_COUNT=3
VITE_API_BASE_URL=http://localhost:3000/api

# Database (if backend is added)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mailflow
DB_USER=postgres
DB_PASSWORD=postgres

# Security
VITE_ENABLE_CORS=true
VITE_CORS_ORIGIN=http://localhost:5173
VITE_SESSION_TIMEOUT_MS=3600000

# Monitoring & Logging
VITE_SENTRY_DSN=
VITE_LOG_TO_FILE=false
VITE_LOG_FILE_PATH=./logs
